# Vercel KV / Upstash Redis
# Dessa skapas automatiskt när du kopplar databasen "svenskajakten" i Vercel:
# Storage → Connect Database → välj "svenskajakten" → lämna "Custom Prefix" TOMT
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx

# Alternativt fungerar också de klassiska Upstash-variablerna:
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Lösenord för lärarvy (valfritt, standard: Korsängen)
TEACHER_PASSWORD=Korsängen
